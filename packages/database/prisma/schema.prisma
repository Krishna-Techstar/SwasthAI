  radiologyReport RadiologyReport? @relation(fields: [radiologyReportId], references: [id], onDelete: SetNull)

  @@index([patientProfileId, createdAt])
  @@index([type, createdAt])
  @@map("ai_insights")
}

model AiProcessingJob {
  id                String      @id @default(uuid()) @db.Uuid
  jobType           String      @map("job_type")
  status            AiJobStatus @default(QUEUED)
  patientProfileId  String?     @map("patient_profile_id") @db.Uuid
  consultationId    String?     @map("consultation_id") @db.Uuid
  radiologyUploadId String?     @map("radiology_upload_id") @db.Uuid
  aiConsentId       String?     @map("ai_consent_id") @db.Uuid
  redisJobId        String?     @map("redis_job_id")
  requestPayload    Json        @map("request_payload")
  resultPayload     Json?       @map("result_payload")
  errorMessage      String?     @map("error_message")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  startedAt         DateTime?   @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?   @map("completed_at") @db.Timestamptz(6)

  patient         PatientProfile? @relation(fields: [patientProfileId], references: [id], onDelete: SetNull)
  consultation    Consultation?   @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  radiologyUpload RadiologyUpload? @relation(fields: [radiologyUploadId], references: [id], onDelete: SetNull)
  aiConsent       AiConsent?      @relation(fields: [aiConsentId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([patientProfileId, createdAt])
  @@map("ai_processing_jobs")
}

model PatientTimelineEvent {
  id               String   @id @default(uuid()) @db.Uuid
  patientProfileId String   @map("patient_profile_id") @db.Uuid
  eventType        String   @map("event_type")
  sourceTable      String   @map("source_table")
  sourceId         String   @map("source_id") @db.Uuid
  summary          String
  searchText       String?  @map("search_text")
  metadata         Json?
  occurredAt       DateTime @map("occurred_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  patient PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)

  @@unique([sourceTable, sourceId, eventType])
  @@index([patientProfileId, occurredAt])
  @@map("patient_timeline_events")
}

model SearchDocument {
  id               String   @id @default(uuid()) @db.Uuid
  patientProfileId String?  @map("patient_profile_id") @db.Uuid
  entityType       String   @map("entity_type")
  entityId         String   @map("entity_id") @db.Uuid
  title            String
  content          String
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  patient PatientProfile? @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId])
  @@index([patientProfileId, updatedAt])
  @@map("search_documents")
}

model RealtimeEventOutbox {
  id               String                 @id @default(uuid()) @db.Uuid
  eventName        String                 @map("event_name")
  aggregateType    String                 @map("aggregate_type")
  aggregateId      String                 @map("aggregate_id") @db.Uuid
  patientProfileId String?                @map("patient_profile_id") @db.Uuid
  actorUserId      String?                @map("actor_user_id") @db.Uuid
  roleScope        Role[]                 @map("role_scope")
  roomNames        String[]               @map("room_names")
  payload          Json
  deliveryStatus   RealtimeDeliveryStatus @default(PENDING) @map("delivery_status")
  attempts         Int                    @default(0)
  publishedAt      DateTime?              @map("published_at") @db.Timestamptz(6)
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([deliveryStatus, createdAt])
  @@index([patientProfileId, createdAt])
  @@map("realtime_event_outbox")
}

model Notification {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  patientProfileId String?   @map("patient_profile_id") @db.Uuid
  type             String
  channel          ReminderChannel
  title            String
  body             String
  payload          Json?
  deliveredAt      DateTime? @map("delivered_at") @db.Timestamptz(6)
  readAt           DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient PatientProfile? @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([patientProfileId, createdAt])
  @@map("notifications")
}

