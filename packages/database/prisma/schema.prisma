  @@index([aiConsentId, createdAt])
  @@map("consent_logs")
}

model AiInsight {
  id                String   @id @default(uuid()) @db.Uuid
  patientProfileId  String   @map("patient_profile_id") @db.Uuid
  consultationId    String?  @map("consultation_id") @db.Uuid
  radiologyReportId String?  @map("radiology_report_id") @db.Uuid
  type              String
  modelName         String   @map("model_name")
  summary           String
  content           Json
  confidence        Decimal? @db.Decimal(5, 4)
  createdByService  String   @map("created_by_service")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  patient         PatientProfile   @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
